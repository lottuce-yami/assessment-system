# Answer Options API

# Get all answer options
# ✅ Should return 200 OK with a list of answer options
# Admin-only
GET {{baseUrl}}/answeroption
Authorization: Bearer {{$dotenv TOKEN}}

###

# Get answer option
# ✅ Should return 200 OK with an answer option
# @prompt id
GET {{baseUrl}}/answeroption/{{id}}
Authorization: Bearer {{$dotenv TOKEN}}

###

# Update answer option
# ✅ Should return 204 No Content
# Admin-only
# @prompt id
# @prompt questionId
PUT {{baseUrl}}/answeroption/{{id}}
Authorization: Bearer {{$dotenv TOKEN}}
Content-Type: application/json

{
    "id": "{{id}}",
    "text": "Test",
    "isCorrect": false,
    "questionId": "{{questionId}}"
}

###

# Add answer option
# ✅ Should return 201 Created with a created answer option
# Admin-only
# @prompt questionId
POST {{baseUrl}}/answeroption
Authorization: Bearer {{$dotenv TOKEN}}
Content-Type: application/json

{
    "text": "test",
    "isCorrect": true,
    "questionId": "{{questionId}}"
}

###

# Delete answer option
# ❌✅ Should return 204 No Content
# Admin-only
# @prompt id
DELETE {{baseUrl}}/answeroption/{{id}}
Authorization: Bearer {{$dotenv TOKEN}}