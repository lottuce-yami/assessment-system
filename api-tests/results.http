# Results API

# Get all results
# ✅ Should return 200 OK with a list of results
GET {{baseUrl}}/result
Authorization: Bearer {{$dotenv TOKEN}}

###

# Get result
# ✅ Should return 200 OK with a result
# @prompt id
GET {{baseUrl}}/result/{{id}}
Authorization: Bearer {{$dotenv TOKEN}}

###

# Update result
# ❌ Should return 204 No Content
# @prompt id

PUT {{baseUrl}}/result/{{id}}
Authorization: Bearer {{$dotenv TOKEN}}

###

# Add result
# ✅ Should return 201 Created with a created result
POST {{baseUrl}}/result
Authorization: Bearer {{$dotenv TOKEN}}
Content-Type: application/json

{
    "quizId": 1,
    "answersId": []
}

###

# Delete result
# ✅ Should return 204 No Content
# @prompt id
DELETE {{baseUrl}}/result/{{id}}
Authorization: Bearer {{$dotenv TOKEN}}